---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE, absoluteUrl } from "../../config/site";
import { ASSETS } from "../../data/assets";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import TrustStrip from "../../components/sections/TrustStrip.astro";
import HowItWorks from "../../components/sections/HowItWorks.astro";
import SpecialistCard from "../../components/sections/SpecialistCard.astro";
import Faq from "../../components/sections/Faq.astro";
import RequestSection from "../../components/sections/RequestSection.astro";

const path = "/loans/";
const title =
  "Asset Loans — Watches, Jewellery, Art, Cars & Gold | ALYRA";
const description =
  "Private asset loans from $50,000 to $5 million against watches, jewellery, fine art, cars, gold bullion and designer handbags. Keep your asset.";

const orgId = absoluteUrl("/") + "#organization";

const crumbs = [
  { name: "Home", href: "/" },
  { name: "Asset Loans" },
];

// Compact trust strip — conservative signals only (no "Licensed pawnbroker"
// here until the licence details in site.ts are final and approved).
const trustItems = [
  { label: "Private enquiry", icon: "lock" },
  { label: "Specialist asset review", icon: "search" },
  { label: "Controlled custody arrangements", icon: "shield" },
  { label: "Loans from $50k to $5m", icon: "clock" },
  { label: "Australia-wide enquiries", icon: "pin" },
] as const;

const processSteps = [
  {
    title: "Share Your Asset Details",
    body: "Submit photos, key details, and any documents you have. ALYRA reviews your enquiry privately and confirms whether the asset may be suitable for assessment.",
  },
  {
    title: "Receive a Specialist Assessment",
    body: "A specialist reviews the asset's condition, documents, value, market demand, and custody requirements.",
  },
  {
    title: "Review Your Loan Offer",
    body: "If approved, you receive a written offer showing the loan amount, fees, interest, repayment terms, redemption rights, and what happens if you do not repay.",
  },
  {
    title: "Receive Funds and Return of Your Asset",
    body: "Once documents are complete and custody is confirmed, funds may be advanced. Your asset is held securely during the loan term and returned once the loan is repaid under the agreed terms.",
  },
];

const eligibilityItems = [
  { label: "Asset type and category", icon: "type" },
  { label: "Estimated market value", icon: "value" },
  { label: "Condition and completeness", icon: "condition" },
  { label: "Provenance and ownership documentation", icon: "provenance" },
  { label: "Authenticity and supporting records", icon: "authenticity" },
  { label: "Resale demand and market liquidity", icon: "demand" },
  { label: "Location and transport requirements", icon: "location" },
  { label: "Custody requirements", icon: "custody" },
  { label: "Applicable law and documentation requirements", icon: "law" },
] as const;

const suitabilityItems = [
  "Own a high-value asset and want to access funds without immediately selling it",
  "Prefer a private, asset-led assessment process",
  "Can provide ownership, authenticity or provenance documentation",
  "Require a structured short-to-medium-term funding option",
  "Understand that the asset is at risk if loan obligations are not met",
];

const whyCards = [
  {
    icon: "eye",
    title: "Private client handling",
    body: "A discreet enquiry process designed for owners of high-value assets.",
  },
  {
    icon: "search",
    title: "Specialist asset focus",
    body: "Focused on luxury watches, jewellery, diamonds, fine art, classic and luxury cars, gold bullion and designer handbags.",
  },
  {
    icon: "doc",
    title: "Clear documentation",
    body: "Offers and terms are documented before the client proceeds.",
  },
  {
    icon: "lock",
    title: "Controlled custody",
    body: "Accepted assets are handled through agreed custody arrangements.",
  },
  {
    icon: "pin",
    title: "Australia-wide enquiries",
    body: "ALYRA reviews enquiries from clients across Australia, with appointments arranged privately where appropriate.",
  },
];

const loansFaqs = [
  {
    q: "What assets can I borrow against?",
    a: "ALYRA may consider luxury watches, jewellery, diamonds, fine art, classic and luxury cars, gold bullion and designer handbags. Each asset is assessed individually based on value, ownership, condition, authenticity, documentation, resale demand and custody requirements.",
  },
  {
    q: "Do I need to sell my asset?",
    a: "No. The purpose of an asset-backed loan is to access liquidity while the asset is held as security. If the loan is repaid in accordance with the agreed terms, the asset is returned.",
  },
  {
    q: "How is the asset valued?",
    a: "Valuation depends on the asset type, market demand, condition, provenance, authenticity, documentation and comparable sale data. ALYRA may request additional information before confirming whether an asset is suitable.",
  },
  {
    q: "Where is the asset held?",
    a: "Assets accepted for lending are held through controlled custody arrangements agreed as part of the loan process. Specific custody requirements depend on the asset type, value, location and agreed loan terms.",
  },
  {
    q: "How long does the process take?",
    a: "Initial review usually begins after asset details are submitted. Timing depends on the asset type, documentation, valuation complexity, custody requirements and client responsiveness.",
  },
  {
    q: "What happens if I do not repay?",
    a: "If a loan is not repaid in accordance with the agreed terms, the pledged asset may be dealt with in accordance with the loan documents and applicable law. Full terms are disclosed before the client proceeds.",
  },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": absoluteUrl(path) + "#webpage",
    url: absoluteUrl(path),
    name: title,
    description,
    isPartOf: { "@id": absoluteUrl("/") + "#website" },
    inLanguage: "en-AU",
    about: { "@id": orgId },
    mainEntity: {
      "@type": "ItemList",
      name: "Assets ALYRA lends against",
      itemListElement: ASSETS.map((a, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: a.card.title,
        url: absoluteUrl(`/loans/${a.slug}/`),
      })),
    },
  },
];
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <!-- Hero -->
  <header class="loans-hero">
    <div class="container">
      <Breadcrumbs items={crumbs} />
      <div class="loans-hero-inner">
        <p class="eyebrow hin">Asset Loans</p>
        <h1 class="loans-h1 hin">Unlock Funds From <span class="hl">Assets You Already Own</span></h1>
        <p class="loans-lead hin">
          ALYRA provides private loans from $50,000 to $5 million secured against eligible luxury
          watches, jewellery, diamonds, fine art, classic and luxury cars, gold bullion, and
          designer handbags.
        </p>
        <div class="loans-cta hin">
          <a class="btn btn--primary" href={SITE.enquiryPath}>Request a Confidential Valuation</a>
        </div>
        <p class="loans-reassure hin">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          Private enquiry · Specialist review · No obligation to proceed.
        </p>
      </div>
    </div>
  </header>

  <TrustStrip items={trustItems} />

  <!-- Asset classes -->
  <section class="section section--rule-gold reveal">
    <div class="container">
      <div class="cat-head">
        <p class="eyebrow">What we lend against</p>
        <h2 class="h2 cat-h2">Assets ALYRA may lend against</h2>
        <p class="lead cat-intro">
          Each asset is assessed individually based on value, ownership, condition, documentation,
          authenticity, resale demand, location, custody requirements and applicable law.
        </p>
      </div>
      <div class="asset-grid">
        {ASSETS.map((a) => (
          <a class="cat-card" href={`/loans/${a.slug}/`}>
            <div class="cat-img-wrap">
              <Image src={a.card.image} alt="" widths={[300, 460, 600]} sizes="(max-width: 600px) 60px, (max-width: 900px) 45vw, 30vw" format="webp" quality={70} loading="lazy" />
            </div>
            <div class="cat-card-body">
              <div class="cat-card-title">{a.card.title}</div>
              <p class="cat-card-blurb">{a.card.blurb}</p>
              <span class="arrow-link cat-card-cta">{a.card.ctaLabel} <span class="arrow">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- What asset-backed lending means -->
  <section class="section section--surface reveal">
    <div class="container abl-split">
      <div class="abl-head">
        <p class="eyebrow">Asset-backed lending</p>
        <h2 class="h2">What asset-backed lending means</h2>
      </div>
      <div class="abl-body">
        <p class="abl-p">
          An asset-backed loan allows you to access funds against an eligible asset without
          immediately selling it. The asset is assessed, documented and held as security. If the loan
          is repaid in accordance with the agreed terms, the asset is returned.
        </p>
        <div class="abl-callout">
          <p>
            This may suit clients who want to access liquidity without immediately selling a luxury,
            collectible or investment-grade asset.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How the process works -->
  <HowItWorks
    id="how"
    white
    heading="Four Steps, Handled Privately"
    intro="From first enquiry to the return of your asset, your application is handled confidentially by an ALYRA specialist."
    steps={processSteps}
    cta={{ label: "View the Full Process", href: "/how-it-works/" }}
  />

  <!-- Your Specialist / Why ALYRA -->
  <section class="section section--surface section--hairline reveal">
    <div class="container">
      <p class="eyebrow">Your specialist</p>
      <h2 class="h2 why-h2">Your specialist — and why clients choose ALYRA</h2>
      <div class="why-spec">
        <SpecialistCard secondLine="From first enquiry through assessment, documentation, custody and completion, you deal directly and confidentially." />
      </div>
      <div class="why-grid">
        {whyCards.map((c) => (
          <div class="why-card">
            <div class="why-icon" aria-hidden="true">
              {c.icon === "eye" && (
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 10 8 10 8a13.2 13.2 0 0 1-1.67 2.68"></path><path d="M6.61 6.61A13.5 13.5 0 0 0 2 12s3 8 10 8a9.7 9.7 0 0 0 5.39-1.61"></path><line x1="2" y1="2" x2="22" y2="22"></line></svg>
              )}
              {c.icon === "search" && (
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
              )}
              {c.icon === "doc" && (
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="9" y1="13" x2="15" y2="13"></line><line x1="9" y1="17" x2="15" y2="17"></line></svg>
              )}
              {c.icon === "lock" && (
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              )}
              {c.icon === "pin" && (
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              )}
            </div>
            <h3 class="why-card-title">{c.title}</h3>
            <p class="why-card-body">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What affects eligibility and valuation -->
  <section class="section section--white section--hairline reveal">
    <div class="container">
      <div class="elig-head">
        <p class="eyebrow">Eligibility &amp; valuation</p>
        <h2 class="h2">What affects eligibility and valuation</h2>
        <p class="lead">
          ALYRA considers both the asset itself and the practical requirements of holding it securely
          as loan security.
        </p>
      </div>
      <ul class="elig-grid">
        {eligibilityItems.map((item) => (
          <li class="elig-item">
            <span class="elig-tick" aria-hidden="true">
              {item.icon === "type" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 2 7l10 5 10-5-10-5z"></path><path d="m2 17 10 5 10-5"></path><path d="m2 12 10 5 10-5"></path></svg>
              )}
              {item.icon === "value" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
              )}
              {item.icon === "condition" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1"></rect><path d="m9 14 2 2 4-4"></path></svg>
              )}
              {item.icon === "provenance" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
              )}
              {item.icon === "authenticity" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
              )}
              {item.icon === "demand" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>
              )}
              {item.icon === "location" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              )}
              {item.icon === "custody" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              )}
              {item.icon === "law" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"></path><path d="M6 21h12"></path><path d="M3 7h18"></path><path d="m6 7-3 6h6l-3-6z"></path><path d="m18 7-3 6h6l-3-6z"></path></svg>
              )}
            </span>
            <span class="elig-label">{item.label}</span>
          </li>
        ))}
      </ul>
      <p class="elig-foot">
        Not every asset will qualify. Suitability depends on valuation, verification, custody,
        documentation, approval and agreed terms.
      </p>
    </div>
  </section>

  <!-- Security, custody and confidentiality -->
  <section class="section section--dark reveal">
    <div class="container sec-cust">
      <p class="eyebrow eyebrow--on-dark">Security &amp; custody</p>
      <h2 class="sec-cust-h2">Security, custody and confidentiality</h2>
      <p class="sec-cust-p">
        Assets accepted for lending are handled through controlled custody arrangements. Enquiries are
        reviewed privately, and asset details are not used to publicly list, market or sell the asset
        during the assessment process.
      </p>
      <p class="sec-cust-p">
        Where an asset proceeds to loan documentation, custody requirements are confirmed before funds
        are advanced. Any storage, insurance or handling arrangements are subject to the asset type,
        approval, policy terms and agreed loan conditions.
      </p>
      <a class="btn btn--gold sec-cust-cta" href="/security-and-custody/">Read About Security &amp; Custody</a>
    </div>
  </section>

  <!-- Loan range and suitability -->
  <section class="section reveal">
    <div class="container suit-split">
      <div>
        <p class="eyebrow">Loan range</p>
        <h2 class="h2">Loan range and suitability</h2>
        <p class="suit-p">
          ALYRA is designed for clients seeking private liquidity from $50,000 to $5 million against
          eligible luxury or collectible assets.
        </p>
        <div class="suit-closing">
          <p>
            All loans are subject to asset type, valuation, approval, custody, documentation and
            agreed loan terms.
          </p>
        </div>
      </div>
      <div class="suit-aside">
        <p class="suit-list-label">This may suit clients who:</p>
        <ul class="suit-list">
          {suitabilityItems.map((s) => (
            <li><span class="suit-dash" aria-hidden="true">—</span>{s}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <Faq
    faqs={loansFaqs}
    heading="Asset loan FAQs"
    intro="Common questions about borrowing against luxury and collectible assets. Anything specific to your asset is discussed privately before you proceed."
    group="loans-faq"
  />

  <!-- Final valuation CTA -->
  <RequestSection
    noun="asset"
    idPrefix="loans"
    heading="Ready to understand what your asset may support?"
    lead="Submit your asset details for private review. An ALYRA specialist will assess the information and contact you confidentially."
    note={null}
    formIntro="Confidential enquiry · No obligation · Specialist review"
  />
</BaseLayout>

<style>
  /* ---- Hero (inner-page pattern) ---- */
  .loans-hero { background: var(--cream); color: var(--ink); padding: calc(var(--nav-offset) + 8px) var(--section-x) clamp(40px, 6vw, 64px); }
  .loans-hero-inner { max-width: 760px; margin-left: auto; margin-right: auto; text-align: center; padding-top: clamp(20px, 4vh, 40px); }
  .loans-hero .eyebrow { margin-bottom: 22px; }
  .loans-h1 {
    font: 600 clamp(36px, 4.8vw, 60px)/1.06 var(--font-display);
    letter-spacing: -1.2px;
    margin: 0 auto 22px;
    text-wrap: balance;
  }
  .loans-h1 .hl { color: var(--gold-fg); }
  .loans-lead { font: 400 clamp(16px, 1.4vw, 19px)/1.7 var(--font-body); color: var(--text-muted); max-width: 640px; margin: 0 auto 26px; }
  .loans-cta { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
  .loans-reassure {
    display: flex; align-items: center; justify-content: center; gap: 9px;
    font: 400 13.5px/1.6 var(--font-body);
    color: #6e6d65;
    margin-top: 16px;
    letter-spacing: .3px;
  }
  .loans-reassure svg { flex: none; opacity: .75; }

  @keyframes hin-rise { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }
  /* H1 rises without fading: an invisible headline delays LCP until the animation reveals it. */
  @keyframes hin-rise-solid { from { transform: translateY(16px); } to { transform: none; } }
  .hin { animation: hin-rise .65s cubic-bezier(.2,.7,.2,1) backwards; }
  .loans-hero .eyebrow.hin { animation-delay: .08s; }
  .loans-h1.hin { animation-name: hin-rise-solid; animation-delay: .17s; }
  .loans-lead.hin { animation-delay: .26s; }
  .loans-hero .btn.hin, .loans-hero div.hin { animation-delay: .35s; }
  .loans-reassure.hin { animation-delay: .44s; }

  /* ---- Asset categories (matches homepage grid) ---- */
  .cat-head { max-width: 680px; margin-bottom: 42px; }
  .cat-h2 { max-width: 620px; }
  .cat-intro { color: var(--text-soft); }
  .asset-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 32px; }
  .cat-card {
    display: flex; flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease;
  }
  .cat-card:hover { transform: translateY(-5px); border-color: var(--gold); box-shadow: 0 16px 38px rgba(40, 38, 30, .13); }
  .cat-img-wrap { overflow: hidden; border-bottom: 1px solid var(--border); }
  .cat-img-wrap img { display: block; width: 100%; height: 230px; object-fit: cover; transition: transform .55s ease; }
  .cat-card:hover .cat-img-wrap img { transform: scale(1.06); }
  .cat-card-body { padding: 30px; display: flex; flex-direction: column; flex: 1; }
  .cat-card-title { font: 600 16px/1.2 var(--font-display); margin-bottom: 8px; }
  .cat-card-blurb { font: 400 13px/1.55 var(--font-body); color: #857f6e; margin: 0 0 16px; }
  .cat-card-cta { margin-top: auto; font: 600 12.5px/1 var(--font-body); color: var(--gold-fg); }

  /* ---- What asset-backed lending means (split) ---- */
  .abl-split { display: grid; grid-template-columns: 0.9fr 1.3fr; gap: clamp(36px, 5vw, 64px); align-items: start; }
  .abl-p { font: 400 17px/1.8 var(--font-body); color: var(--text-muted); margin: 0 0 26px; }
  .abl-callout {
    border-left: 2px solid var(--gold);
    background: var(--surface);
    border-radius: 0 var(--radius-card) var(--radius-card) 0;
    padding: 22px 26px;
  }
  .abl-callout p { font: 500 16px/1.6 var(--font-display); color: var(--ink); margin: 0; letter-spacing: -0.2px; }

  /* ---- Eligibility & valuation ---- */
  .elig-head { max-width: 640px; margin-bottom: 40px; }
  .elig-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px 40px; }
  .elig-item { display: flex; gap: 14px; align-items: center; padding: 16px 0; border-top: 1px solid var(--border); }
  .elig-tick { flex: none; width: 30px; height: 30px; border-radius: 50%; background: rgba(196, 165, 103, .16); display: flex; align-items: center; justify-content: center; color: var(--gold-fg); }
  .elig-label { font: 500 15.5px/1.4 var(--font-body); color: var(--ink); }
  .elig-foot { font: 400 15px/1.7 var(--font-body); color: var(--text-soft); margin: 32px 0 0; max-width: 720px; }

  /* ---- Security, custody & confidentiality (dark) ---- */
  .sec-cust { max-width: 760px; }
  .sec-cust-h2 { font: 600 clamp(28px, 3.4vw, 40px)/1.1 var(--font-display); letter-spacing: -0.6px; color: var(--cream); margin: 0 0 20px; }
  .sec-cust-p { font: 400 16px/1.75 var(--font-body); color: var(--text-on-dark-soft); margin: 0 0 18px; }
