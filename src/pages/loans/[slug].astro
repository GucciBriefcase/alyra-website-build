---
import type { GetStaticPaths } from "astro";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE, absoluteUrl } from "../../config/site";
import { ASSETS, relatedAssets, type Asset } from "../../data/assets";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AssessIcon from "../../components/AssessIcon.astro";
import HowItWorks from "../../components/sections/HowItWorks.astro";
import SecurityCustody from "../../components/sections/SecurityCustody.astro";
import SpecialistCard from "../../components/sections/SpecialistCard.astro";
import Faq from "../../components/sections/Faq.astro";
import RequestSection from "../../components/sections/RequestSection.astro";

export const getStaticPaths = (() => {
  return ASSETS.map((asset) => ({
    params: { slug: asset.slug },
    props: { asset },
  }));
}) satisfies GetStaticPaths;

interface Props {
  asset: Asset;
}
const { asset } = Astro.props;
const path = `/loans/${asset.slug}/`;
const orgId = absoluteUrl("/") + "#organization";
const noun = asset.noun;
const related = relatedAssets(asset.slug);

const howSteps = [
  { title: `Share your ${noun} details`, body: `Submit photos, key details and any documents you have. ALYRA reviews your enquiry privately and confirms whether the ${noun} is suitable for assessment.` },
  { title: "Receive a specialist assessment", body: `A specialist reviews the ${noun}'s condition, documents, value, authenticity and market demand.` },
  { title: "Review your loan offer", body: "If approved, you receive a written offer setting out the loan amount, fees, interest, repayment terms and redemption rights before you proceed." },
  { title: `Repay and retrieve your ${noun}`, body: `Your ${noun} is held securely during the loan term and returned once the loan is repaid under the agreed terms.` },
];

const custodySteps = [
  { title: "Documented on arrival", body: `The ${noun} is received, identified and reviewed against available documents.` },
  { title: "Photographed & catalogued", body: "Its condition and details are photographed and recorded before custody." },
  { title: "Held in secure custody", body: `The ${noun} is held securely for the agreed loan term, subject to custody and insurance terms.` },
  { title: "Returned after repayment", body: `Once the loan is repaid under the agreed terms, the ${noun} is returned to you.` },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: asset.title.replace(" | ALYRA", ""),
    serviceType: asset.serviceType,
    provider: { "@id": orgId },
    areaServed: SITE.serviceAreaCode,
    description: asset.serviceDescription,
    offers: {
      "@type": "Offer",
      priceCurrency: SITE.currency,
      priceSpecification: {
        "@type": "PriceSpecification",
        minPrice: SITE.loanMin,
        maxPrice: SITE.loanMax,
        priceCurrency: SITE.currency,
      },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": absoluteUrl(path) + "#webpage",
    url: absoluteUrl(path),
    name: asset.title,
    isPartOf: { "@id": absoluteUrl("/") + "#website" },
    inLanguage: "en-AU",
    datePublished: "2026-06-01",
    dateModified: "2026-06-27",
    primaryImageOfPage: absoluteUrl(asset.ogImage),
  },
];

const crumbs = [
  { name: "Home", href: "/" },
  { name: asset.breadcrumbName },
];
---

<BaseLayout
  title={asset.title}
  description={asset.metaDescription}
  path={path}
  image={asset.ogImage}
  imageAlt={asset.heroImageAlt}
  schema={schema}
>
  <!-- ===== HERO ===== -->
  <header class="hero">
    <div class="container">
      <Breadcrumbs items={crumbs} />
      <div class="hero-grid">
        <div>
          <p class="eyebrow hin">{asset.heroEyebrow}</p>
          <h1 class="hero-h1 hin">{asset.h1Lead} <span class="hl">{asset.h1Highlight}</span></h1>
          <p class="hero-intro1 hin">{asset.heroIntro1}</p>
          <p class="hero-intro2 hin">{asset.heroIntro2}</p>
          <div class="hin"><a class="btn btn--primary" href={SITE.enquiryPath}>Request a Confidential Valuation</a></div>
          <p class="hero-reassure hin">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            Licensed pawnbroker · Specialist response usually within one business day
          </p>
        </div>
        <div class="hero-img hin" style={`background:${asset.heroBg}`}>
          <Image src={asset.heroImage} alt={asset.heroImageAlt} widths={[480, 768, 1100]} sizes="(max-width: 900px) 100vw, 50vw" format="webp" quality={72} loading="eager" fetchpriority="high" />
        </div>
      </div>
    </div>
  </header>

  <!-- ===== A LOAN, NOT A SALE ===== -->
  <section class="section section--cream-deep reveal">
    <div class="container lns-split">
      <div>
        <p class="eyebrow">Keep your {asset.keepLabel}</p>
        <h2 class="lns-h2">A loan, not a sale.</h2>
      </div>
      <div>
        {asset.loanNotSaleLead && <p class="lns-lead">{asset.loanNotSaleLead}</p>}
        <p class="lns-p">{asset.loanNotSaleP1}</p>
        <p class="lns-p">{asset.loanNotSaleP2}</p>
        <div class="lns-closing"><p>{asset.closingLine}</p></div>
      </div>
    </div>
  </section>

  <!-- ===== BRANDS WE LEND AGAINST ===== -->
  <section id="brands" class="section section--white section--hairline reveal">
    <div class="container">
      <div class="brand-head">
        <p class="eyebrow">What we lend against</p>
        <h2 class="h2">{asset.brandHeading}</h2>
        <p class="lead">{asset.brandIntro}</p>
      </div>
      <div class="brand-grid">
        {asset.brands.map((b) => <div class="brand-tile">{b}</div>)}
      </div>
      <p class="brand-foot">{asset.brandFootnote}</p>
    </div>
  </section>

  <!-- ===== HOW MUCH YOU CAN BORROW ===== -->
  <section class="section reveal">
    <div class="container range-split">
      <div>
        <p class="eyebrow">Loan range</p>
        <h2 class="range-h2">How much you can borrow.</h2>
        <div class="range-figure">{SITE.loanRangeLabel}</div>
        <p class="range-p">{asset.loanRangeIntro1}</p>
        <p class="range-p">{asset.loanRangeIntro2}</p>
      </div>
      <Image class="range-img" src={asset.loanRangeImage} alt={asset.loanRangeImageAlt} widths={[480, 768, 1080]} sizes="(max-width: 900px) 100vw, 50vw" format="webp" quality={70} loading="lazy" />
    </div>
  </section>

  <!-- ===== WHAT WE ASSESS ===== -->
  <section class="section section--surface section--hairline reveal">
    <div class="container">
      <div class="assess-head">
        <p class="eyebrow">Specialist assessment</p>
        <h2 class="h2">What we assess.</h2>
        <p class="lead">{asset.assessIntro}</p>
      </div>
      <ul class="assess-grid">
        {asset.assessItems.map((item) => (
          <li class="assess-item">
            <span class="assess-icon"><AssessIcon name={item.icon} /></span>
            <span class="assess-label">{item.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <HowItWorks
    id="how"
    heading={`From confidential enquiry to ${noun} return.`}
    intro={`A simple, private process from first enquiry to the return of your ${noun}.`}
    steps={howSteps}
  />

  <!-- ===== SECURITY & CUSTODY ===== -->
  <SecurityCustody
    lead={[
      `When a loan proceeds, your ${noun} is documented on arrival, photographed and held in secure custody for the agreed term. Insurance may apply while it is held, subject to policy terms, asset approval, valuation limits and custody conditions.`,
      `You remain the owner throughout. ALYRA holds the ${noun} only as security for the loan.`,
    ]}
    steps={custodySteps}
  />

  <!-- ===== DISCRETION ===== -->
  <section class="section reveal">
    <div class="container disc">
      <p class="eyebrow">Discretion</p>
      <h2 class="disc-h2">Handled in confidence.</h2>
      <p class="disc-p">Your enquiry is private from the first contact.</p>
      <p class="disc-p">
        Your {noun} is never listed, marketed or sent to auction. You deal confidentially through
        assessment, custody and completion.
      </p>
    </div>
  </section>

  <!-- ===== BORROW OR SELL ===== -->
  <section class="section section--surface section--hairline reveal">
    <div class="container bos">
      <div class="bos-head">
        <p class="eyebrow">Your options</p>
        <h2 class="bos-h2">Borrow or sell privately.</h2>
      </div>
      <div class="bos-cards">
        <div class="bos-card bos-card--dark">
          <div class="bos-tag bos-tag--gold">Borrow</div>
          <p class="bos-card-p bos-card-p--dark">
            Borrowing may suit clients who want access to funds while keeping ownership of their {noun}
            during the loan term.
          </p>
        </div>
        <div class="bos-card bos-card--light">
          <div class="bos-tag">Sell</div>
          <p class="bos-card-p">
            If you are ready to sell permanently, ALYRA may also provide a private purchase offer where
            available. Any decision to sell is considered separately from borrowing.
          </p>
        </div>
      </div>
      <div class="bos-cta"><a class="btn btn--primary" href={SITE.enquiryPath}>Request a Confidential Valuation</a></div>
    </div>
  </section>

  <!-- ===== SPECIALIST ===== -->
  <section id="specialist" class="section section--rule-gold reveal">
    <div class="container spec-section">
      <div class="spec-head">
        <p class="eyebrow">Your specialist</p>
        <h2 class="h2">Speak with a specialist.</h2>
      </div>
      <SpecialistCard secondLine="From first enquiry to completion, you deal directly and confidentially." />
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <Faq
    faqs={asset.faqs}
    heading="Common questions."
    intro={`Everything else is explained privately before you proceed. Speak with a specialist about your ${noun} in confidence.`}
    group={`${asset.slug}-faq`}
    white={false}
  />

  <!-- ===== RELATED ASSETS (internal links) ===== -->
  <section class="section section--surface section--hairline reveal">
    <div class="container">
      <div class="rel-head">
        <p class="eyebrow">Explore</p>
        <h2 class="h2">Other assets we lend against.</h2>
      </div>
      <div class="rel-grid">
        {related.map((r) => (
          <a class="rel-card" href={`/loans/${r.slug}/`}>
            <Image src={r.card.image} alt={r.card.title} widths={[260, 400]} sizes="(max-width: 600px) 90vw, 30vw" format="webp" quality={70} loading="lazy" />
            <div class="rel-card-body">
              <span class="rel-card-title">{r.card.title}</span>
              <span class="arrow-link rel-card-cta">{r.card.ctaLabel} <span class="arrow">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== REQUEST ===== -->
  <RequestSection noun={noun} preselect={asset.breadcrumbName} idPrefix={asset.slug} />
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero { background: var(--cream); color: var(--ink); padding: calc(var(--nav-offset) + 24px) var(--section-x) 0; border-bottom: 1px solid var(--gold); }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr .95fr;
    gap: clamp(40px, 6vw, 76px);
    align-items: center;
    padding: clamp(48px, 9vh, 104px) 0 clamp(44px, 7vh, 84px);
  }
  .hero-h1 {
    font: 600 clamp(38px, 5vw, 62px)/1.05 var(--font-display);
    letter-spacing: -1.4px;
    margin: 0 0 24px;
    text-wrap: balance;
  }
  .hero-h1 .hl { color: var(--gold-fg); }
  .hero-intro1 { font: 400 clamp(16px, 1.4vw, 19px)/1.6 var(--font-body); color: var(--text-chip); max-width: 520px; margin: 0 0 16px; }
  .hero-intro2 { font: 400 15px/1.7 var(--font-body); color: var(--text-soft); max-width: 520px; margin: 0 0 30px; }
  .hero-reassure { display: flex; align-items: center; gap: 9px; font: 400 13px/1.6 var(--font-body); color: #6e6d65; margin-top: 18px; letter-spacing: .2px; }
  .hero-reassure svg { flex: none; opacity: .75; }
  .hero-img {
    height: clamp(360px, 54vh, 580px);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 30px 70px rgba(40, 38, 30, .2);
  }
  .hero-img img { display: block; width: 100%; height: 100%; object-fit: cover; }

  @keyframes hin-rise { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }
  .hin { animation: hin-rise .65s cubic-bezier(.2,.7,.2,1) backwards; }
  .eyebrow.hin { animation-delay: .08s; }
  .hero-h1.hin { animation-delay: .17s; }
  .hero-intro1.hin { animation-delay: .26s; }
  .hero-intro2.hin { animation-delay: .33s; }
  .hero-img.hin { animation-delay: .2s; }

  /* ---- A loan, not a sale ---- */
  .lns-split { display: grid; grid-template-columns: 0.9fr 1.3fr; gap: clamp(36px, 5vw, 64px); align-items: start; }
  .lns-h2 { font: 600 clamp(28px, 3.4vw, 40px)/1.08 var(--font-display); letter-spacing: -0.8px; margin: 0; }
  .lns-lead { font: 500 18px/1.7 var(--font-display); color: var(--ink); margin: 0 0 18px; letter-spacing: -0.2px; }
  .lns-p { font: 400 17px/1.8 var(--font-body); color: var(--text-muted); margin: 0 0 16px; }
  .lns-closing { border-top: 1px solid var(--border); padding-top: 22px; margin-top: 10px; }
  .lns-closing p { font: 500 18px/1.5 var(--font-display); color: var(--ink); margin: 0; letter-spacing: -0.2px; }

  /* ---- Brands ---- */
  .brand-head { max-width: 680px; margin-bottom: 44px; }
  .brand-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 18px; }
  .brand-tile {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
    padding: 30px 18px;
    text-align: center;
    font: 500 17px/1.25 var(--font-display);
    color: var(--ink);
    display: flex; align-items: center; justify-content: center;
    min-height: 92px;
    transition: transform .3s cubic-bezier(.2,.7,.2,1), border-color .3s ease, background .3s ease, box-shadow .3s ease;
  }
  .brand-tile:hover { transform: translateY(-4px); border-color: var(--gold); background: #fff; box-shadow: 0 14px 32px rgba(40, 38, 30, .1); }
  .brand-foot { font: 400 15px/1.7 var(--font-body); color: var(--text-soft); margin: 28px 0 0; max-width: 680px; }

  /* ---- Loan range ---- */
  .range-split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(40px, 6vw, 72px); align-items: center; }
  .range-h2 { font: 600 clamp(28px, 3.4vw, 40px)/1.1 var(--font-display); letter-spacing: -0.6px; margin: 0 0 22px; }
  .range-figure { font: 600 clamp(40px, 5.4vw, 64px)/1 var(--font-display); letter-spacing: -1.5px; color: var(--ink); margin-bottom: 24px; }
  .range-p { font: 400 16px/1.75 var(--font-body); color: var(--text-muted); margin: 0 0 16px; }
  .range-img { display: block; width: 100%; height: clamp(320px, 42vw, 440px); object-fit: cover; border-radius: var(--radius-card); box-shadow: 0 24px 56px rgba(40, 38, 30, .16); }

  /* ---- What we assess ---- */
  .assess-head { max-width: 640px; margin-bottom: 40px; }
  .assess-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px 40px; }
  .assess-item { display: flex; gap: 14px; align-items: center; padding: 16px 0; border-top: 1px solid var(--border); }
  .assess-icon { flex: none; width: 30px; height: 30px; border-radius: 50%; background: rgba(196, 165, 103, .16); display: flex; align-items: center; justify-content: center; }
  .assess-label { font: 500 15.5px/1.4 var(--font-body); color: var(--ink); }

  /* ---- Discretion ---- */
  .disc { max-width: 760px; margin: 0 auto; text-align: center; }
  .disc-h2 { font: 600 clamp(28px, 3.4vw, 42px)/1.1 var(--font-display); letter-spacing: -0.8px; margin: 0 0 22px; }
  .disc-p { font: 400 17px/1.8 var(--font-body); color: var(--text-muted); margin: 0 auto 14px; max-width: 600px; }

  /* ---- Borrow or sell ---- */
  .bos { max-width: 980px; }
  .bos-head { text-align: center; margin-bottom: clamp(36px, 4vw, 46px); }
  .bos-head .eyebrow { margin-left: auto; margin-right: auto; }
  .bos-h2 { font: 600 clamp(28px, 3.4vw, 42px)/1.1 var(--font-display); letter-spacing: -0.8px; margin: 0; }
  .bos-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .bos-card { border-radius: var(--radius-card); padding: 38px 36px; }
  .bos-card--dark { background: var(--ink); color: #f1ece1; }
  .bos-card--light { background: #fff; border: 1px solid var(--border); }
  .bos-tag { font: 600 12px/1 var(--font-body); letter-spacing: 2px; text-transform: uppercase; color: var(--gold-fg); margin-bottom: 14px; }
  .bos-tag--gold { color: var(--gold); }
  .bos-card-p { font: 400 16px/1.7 var(--font-body); color: var(--text-muted); margin: 0; }
  .bos-card-p--dark { color: var(--text-on-dark-soft); }
  .bos-cta { text-align: center; margin-top: clamp(32px, 4vw, 40px); }

  /* ---- Specialist ---- */
  .spec-section { max-width: 1000px; }
  .spec-head { text-align: center; margin-bottom: 40px; }
  .spec-head .eyebrow { margin-left: auto; margin-right: auto; }

  /* ---- Related ---- */
  .rel-head { margin-bottom: 32px; }
  .rel-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; }
  .rel-card { display: flex; flex-direction: column; background: #fff; border: 1px solid var(--border); border-radius: var(--radius-card); overflow: hidden; text-decoration: none; color: inherit; transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease; }
  .rel-card:hover { transform: translateY(-4px); border-color: var(--gold); box-shadow: 0 14px 32px rgba(40, 38, 30, .12); }
  .rel-card img { display: block; width: 100%; height: 150px; object-fit: cover; }
  .rel-card-body { padding: 20px 22px; display: flex; flex-direction: column; gap: 10px; }
  .rel-card-title { font: 600 16px/1.25 var(--font-display); }
  .rel-card-cta { font: 600 12.5px/1 var(--font-body); color: var(--gold-fg); }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero-img { order: -1; }
    .range-split { grid-template-columns: 1fr; }
  }
  @media (max-width: 820px) {
    .brand-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .assess-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) { .lns-split { grid-template-columns: 1fr; gap: 24px; } }
  @media (max-width: 640px) { .bos-cards { grid-template-columns: 1fr; } }
</style>
