---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, absoluteUrl } from "../config/site";
import { ASSETS } from "../data/assets";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import TrustStrip from "../components/sections/TrustStrip.astro";
import SpecialistCard from "../components/sections/SpecialistCard.astro";
import RequestSection from "../components/sections/RequestSection.astro";

const path = "/about/";
const title = "About ALYRA | Private Asset-Based Lending";
const description =
  "ALYRA is a private asset-based lending business in Australia, helping clients access funds from $50,000 to $5 million secured against eligible high-value assets they would rather keep than sell.";

const crumbs = [
  { name: "Home", href: "/" },
  { name: "About" },
];

// Hero trust points (compact, conservative signals).
const trustItems = [
  { label: "Specialist valuation", icon: "search" },
  { label: "Secure custody", icon: "lock" },
  { label: "Loans from $50k to $5m", icon: "clock" },
  { label: "Australia-wide enquiries", icon: "pin" },
] as const;

// What makes ALYRA different — four clear points.
const differentiators = [
  {
    title: "Private enquiries",
    body: "Every enquiry is handled confidentially. Your asset is not publicly listed, marketed or sent to auction.",
  },
  {
    title: "Specialist-led valuation",
    body: "Eligible assets are reviewed by a specialist who understands the market for what you own.",
  },
  {
    title: "Lending, not buying",
    body: "ALYRA lends against your asset rather than buying it, so you can access funds without selling.",
  },
  {
    title: "Secure custody if a loan proceeds",
    body: "If a loan proceeds, the asset is documented and held through controlled custody arrangements for the agreed term.",
  },
];

// Who ALYRA helps.
const clientTypes = [
  { label: "Private clients with high-value assets", icon: "gem" },
  { label: "Collectors who do not want to sell", icon: "collection" },
  { label: "Business owners seeking liquidity", icon: "briefcase" },
  { label: "Clients managing timing gaps, settlements or opportunities", icon: "clock" },
  { label: "Clients seeking a private alternative to public sale or auction", icon: "lock" },
] as const;

// Licensing & compliance — confirmed details live in site.ts. Bracketed values
// are placeholders to be replaced before launch.
const compliance = [
  { label: "Legal entity", value: SITE.legalEntity },
  { label: "ABN", value: SITE.abn },
  { label: "Pawnbroker licence", value: SITE.pawnbrokerLicence },
  { label: "Second-hand dealer registration", value: SITE.secondHandDealerRegistration },
  { label: "Jurisdiction", value: SITE.serviceArea },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": absoluteUrl(path) + "#webpage",
    url: absoluteUrl(path),
    name: title,
    description,
    isPartOf: { "@id": absoluteUrl("/") + "#website" },
    inLanguage: "en-AU",
    about: { "@id": absoluteUrl("/") + "#organization" },
  },
];
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <!-- Hero -->
  <header class="about-hero">
    <div class="container">
      <Breadcrumbs items={crumbs} />
      <div class="about-hero-inner">
        <p class="eyebrow hin">About ALYRA</p>
        <h1 class="about-h1 hin">
          Private asset-based lending for clients who would rather <span class="hl">keep than sell</span>.
        </h1>
        <p class="about-lead hin">
          ALYRA is a private asset-based lending business in Australia. We help clients access funds
          from $50,000 to $5 million secured against eligible high-value assets — without selling what
          they value.
        </p>
        <div class="hin"><a class="btn btn--primary" href={SITE.enquiryPath}>Request a Confidential Valuation</a></div>
        <p class="about-reassure hin">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          Private enquiry · Specialist review · No obligation to proceed.
        </p>
      </div>
    </div>
  </header>

  <TrustStrip items={trustItems} />

  <!-- Who ALYRA is and why it exists -->
  <section class="section section--white reveal">
    <div class="container">
      <div class="about-intro">
        <p class="eyebrow">Who we are</p>
        <h2 class="h2 about-h2">Another option to selling.</h2>
        <p class="about-p">
          ALYRA helps private clients in Australia access funds secured against eligible high-value
          assets they would rather keep than sell.
        </p>
        <p class="about-p">
          Selling a valued asset can be final. ALYRA gives clients another option — borrowing against the
          asset while retaining ownership, subject to valuation, approval, custody, documentation and
          agreed terms.
        </p>
      </div>
    </div>
  </section>

  <!-- What makes ALYRA different -->
  <section class="section section--surface section--hairline reveal">
    <div class="container">
      <div class="about-diff-head">
        <p class="eyebrow">What makes us different</p>
        <h2 class="h2 about-h2">A private, specialist-led approach.</h2>
      </div>
      <div class="about-diff-grid">
        {differentiators.map((d) => (
          <div class="about-card">
            <h3 class="about-card-title">{d.title}</h3>
            <p class="about-card-body">{d.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who you deal with -->
  <section class="section section--white section--rule reveal">
    <div class="container">
      <div class="about-spec-head">
        <p class="eyebrow">Who you deal with</p>
        <h2 class="h2 about-h2">Led by a valuation specialist.</h2>
        <p class="lead about-spec-intro">
          Eden John is ALYRA's Principal Valuation Specialist. He leads the valuation process, with
          experience across high-value watches, jewellery, diamonds and collectible assets, and
          supports clients through each stage of assessment.
        </p>
      </div>
      <SpecialistCard
        tags={["MBA", "10 years' experience", "Watches, jewellery, diamonds, and collectible assets"]}
        secondLine="From first enquiry through assessment, documentation, custody and completion, clients deal directly and confidentially."
      />
    </div>
  </section>

  <!-- Assets ALYRA understands -->
  <section class="section reveal">
    <div class="container about-assets-wrap">
      <div class="about-assets-head">
        <p class="eyebrow">What we lend against</p>
        <h2 class="h2 about-h2">Assets ALYRA understands.</h2>
      </div>
      <div class="about-asset-grid">
        {ASSETS.map((a) => (
          <a class="about-asset-card" href={`/loans/${a.slug}/`}>
            <div class="about-asset-img">
              <Image src={a.card.image} alt="" widths={[300, 460, 600]} sizes="(max-width: 600px) 90vw, (max-width: 900px) 45vw, 30vw" format="webp" quality={70} loading="lazy" />
            </div>
            <div class="about-asset-body">
              <div class="about-asset-title">{a.card.title}</div>
              <p class="about-asset-blurb">{a.card.blurb}</p>
              <span class="arrow-link about-asset-cta">{a.card.ctaLabel} <span class="arrow">→</span></span>
            </div>
          </a>
        ))}
      </div>
      <p class="about-assets-note">
        ALYRA also considers select collectibles. Suitability depends on ownership, documentation,
        condition, valuation and market demand.
      </p>
    </div>
  </section>

  <!-- Confidentiality and security -->
  <section class="section section--dark reveal">
    <div class="container about-conf">
      <p class="eyebrow eyebrow--on-dark">Confidentiality &amp; security</p>
      <h2 class="about-conf-h2">Handled privately, end to end.</h2>
      <p class="about-conf-p">
        Enquiries are reviewed privately. Your asset details are not used to publicly list, market or
        sell the asset as part of the enquiry process.
      </p>
      <p class="about-conf-p">
        If a loan proceeds, the asset is held through controlled custody arrangements that are confirmed
        before any funds are advanced. {SITE.insuranceNote}
      </p>
      <a class="btn btn--gold about-conf-cta" href="/security-and-custody/">Read About Security &amp; Custody</a>
    </div>
  </section>

  <!-- Who ALYRA helps -->
  <section class="section section--surface section--hairline reveal">
    <div class="container about-help">
      <div class="about-help-head">
        <p class="eyebrow">Who we help</p>
        <h2 class="h2 about-h2">Who ALYRA is for.</h2>
      </div>
      <ul class="about-help-grid">
        {clientTypes.map((c) => (
          <li class="about-help-card">
            <span class="about-help-icon" aria-hidden="true">
              {c.icon === "gem" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l4 6-10 13L2 9z"></path><path d="M11 3 8 9l4 13 4-13-3-6"></path><path d="M2 9h20"></path></svg>
              )}
              {c.icon === "collection" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="5" rx="1"></rect><path d="M4 9v9a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9"></path><path d="M10 13h4"></path></svg>
              )}
              {c.icon === "briefcase" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
              )}
              {c.icon === "clock" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><polyline points="12 7 12 12 15 14"></polyline></svg>
              )}
              {c.icon === "lock" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              )}
            </span>
            <span class="about-help-label">{c.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Licensing and compliance -->
  <section class="section section--white reveal about-compliance-sec">
    <div class="container about-compliance">
      <p class="eyebrow">Licensing &amp; compliance</p>
      <h2 class="h2 about-h2">Licensing and compliance.</h2>
      <p class="about-p">
        ALYRA provides loans to private clients secured against pledged high-value assets. Confirmed
        entity and regulatory details are set out below and finalised ahead of launch.
      </p>
      <dl class="about-compliance-card">
        {compliance.map((row) => (
          <div class="about-compliance-row">
            <dt>{row.label}</dt>
            <dd>{row.value}</dd>
          </div>
        ))}
      </dl>
      <a class="btn btn--outline about-compliance-cta" href="/licence/">View Licensing &amp; Registration</a>
    </div>
  </section>

  <!-- Final CTA -->
  <RequestSection
    noun="asset"
    idPrefix="about"
    heading="Request a Confidential Valuation"
    lead="Submit your asset details for private review. An ALYRA specialist will contact you confidentially."
    note="Submitting an enquiry does not guarantee approval or funding."
  />
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .about-hero { background: var(--cream); color: var(--ink); padding: calc(var(--nav-offset) + 8px) var(--section-x) clamp(40px, 6vw, 64px); }
  .about-hero-inner { max-width: 780px; margin-left: auto; margin-right: auto; text-align: center; padding-top: clamp(20px, 4vh, 40px); }
  .about-hero .eyebrow { margin-bottom: 22px; }
  .about-h1 {
    font: 600 clamp(34px, 4.6vw, 58px)/1.07 var(--font-display);
    letter-spacing: -1.2px;
    margin: 0 auto 22px;
    text-wrap: balance;
  }
  .about-h1 .hl { color: var(--gold-fg); }
  .about-lead { font: 400 clamp(16px, 1.4vw, 19px)/1.7 var(--font-body); color: var(--text-muted); max-width: 660px; margin: 0 auto 26px; }
  .about-reassure {
    display: flex; align-items: center; justify-content: center; gap: 9px;
    font: 400 13.5px/1.6 var(--font-body);
    color: #6e6d65;
    margin-top: 16px;
    letter-spacing: .3px;
  }
  .about-reassure svg { flex: none; opacity: .75; }

  @keyframes hin-rise { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }
  .hin { animation: hin-rise .65s cubic-bezier(.2,.7,.2,1) backwards; }
  .about-hero .eyebrow.hin { animation-delay: .08s; }
  .about-h1.hin { animation-delay: .17s; }
  .about-lead.hin { animation-delay: .26s; }
  .about-hero .btn.hin, .about-hero div.hin { animation-delay: .35s; }
  .about-reassure.hin { animation-delay: .44s; }

  /* ---- Shared text ---- */
  .about-h2 { max-width: 620px; }
  .about-p { font: 400 16px/1.8 var(--font-body); color: var(--text-muted); margin: 18px 0 0; max-width: 700px; }
  .about-intro { max-width: 720px; }

  /* ---- What makes us different (4 cards) ---- */
  .about-diff-head { max-width: 620px; margin-bottom: 40px; }
  .about-diff-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 28px; }
  .about-card {
    background: var(--surface-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: 32px 30px;
  }
  .about-card-title { font: 600 18px/1.3 var(--font-display); margin: 0 0 10px; }
  .about-card-body { font: 400 14.5px/1.7 var(--font-body); color: var(--text-soft); margin: 0; }

  /* ---- Specialist (centered) ---- */
  .about-spec-head { max-width: 660px; margin: 0 auto 36px; text-align: center; }
  .about-spec-head .eyebrow { margin-left: auto; margin-right: auto; }
  .about-spec-intro { color: var(--text-soft); }

  /* ---- Assets understood (photo grid) ---- */
  .about-assets-head { max-width: 620px; margin-bottom: 36px; }
  .about-asset-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 32px; }
  .about-asset-card {
    display: flex; flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease;
  }
  .about-asset-card:hover { transform: translateY(-5px); border-color: var(--gold); box-shadow: 0 16px 38px rgba(40, 38, 30, .13); }
  .about-asset-img { overflow: hidden; border-bottom: 1px solid var(--border); }
  .about-asset-img img { display: block; width: 100%; height: 230px; object-fit: cover; transition: transform .55s ease; }
  .about-asset-card:hover .about-asset-img img { transform: scale(1.06); }
  .about-asset-body { padding: 30px; display: flex; flex-direction: column; flex: 1; }
  .about-asset-title { font: 600 16px/1.2 var(--font-display); margin-bottom: 8px; }
  .about-asset-blurb { font: 400 13px/1.55 var(--font-body); color: #857f6e; margin: 0 0 16px; }
  .about-asset-cta { margin-top: auto; font: 600 12.5px/1 var(--font-body); color: var(--gold-fg); }
  .about-assets-note { font: 400 15px/1.7 var(--font-body); color: var(--text-soft); margin: 28px 0 0; max-width: 720px; }

  /* ---- Confidentiality (dark, centered) ---- */
  .about-conf { max-width: 760px; margin: 0 auto; text-align: center; }
  .about-conf .eyebrow { margin-left: auto; margin-right: auto; }
  .about-conf-h2 { font: 600 clamp(28px, 3.4vw, 40px)/1.1 var(--font-display); letter-spacing: -0.6px; color: var(--cream); margin: 0 0 20px; }
  .about-conf-p { font: 400 16px/1.75 var(--font-body); color: var(--text-on-dark-soft); margin: 0 0 18px; }
  .about-conf-cta { margin-top: 14px; }

  /* ---- Who we help ---- */
  .about-help-head { max-width: 620px; margin: 0 auto 36px; text-align: center; }
  .about-help-head .eyebrow { margin-left: auto; margin-right: auto; }
  .about-help-grid { list-style: none; margin: 0 auto; padding: 0; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; max-width: 880px; }
  .about-help-card {
    display: flex; align-items: center; gap: 16px;
    background: var(--surface-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: 22px 26px;
    font: 500 16px/1.4 var(--font-body);
    color: var(--ink);
    text-align: left;
  }
  .about-help-card:last-child { grid-column: 1 / -1; justify-content: center; }
  .about-help-icon { flex: none; width: 40px; height: 40px; border-radius: 50%; background: rgba(196, 165, 103, .16); color: var(--gold-fg); display: flex; align-items: center; justify-content: center; }

  /* ---- Licensing & compliance (centered) ---- */
  .about-compliance-sec { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(48px, 6vw, 80px); }
  .about-compliance { max-width: 760px; margin: 0 auto; text-align: center; }
  .about-compliance .eyebrow { margin-left: auto; margin-right: auto; }
  .about-compliance .about-h2,
  .about-compliance .about-p { margin-left: auto; margin-right: auto; }
  .about-compliance-card {
    margin: 52px auto 0;
    max-width: 660px;
    background: var(--surface-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: 8px 34px;
    text-align: left;
  }
  .about-compliance-row {
    display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
    padding: 18px 0;
    border-top: 1px solid var(--border);
  }
  .about-compliance-row:first-child { border-top: none; }
  .about-compliance-row dt { font: 600 14px/1.5 var(--font-body); color: var(--ink); margin: 0; }
  .about-compliance-row dd { font: 400 14.5px/1.5 var(--font-body); color: var(--text-muted); margin: 0; text-align: right; }
  .about-compliance-cta { display: block; max-width: 660px; margin: 24px auto 0; text-align: center; }

  @media (max-width: 900px) { .about-asset-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 860px) { .about-diff-grid { grid-template-columns: 1fr; } }
  @media (max-width: 600px) {
    .about-asset-grid { grid-template-columns: 1fr; }
    .about-help-grid { grid-template-columns: 1fr; }
    .about-help-card:last-child { grid-column: auto; justify-content: flex-start; }
    .about-compliance-row { flex-direction: column; align-items: flex-start; gap: 4px; }
    .about-compliance-row dd { text-align: left; }
  }
</style>
