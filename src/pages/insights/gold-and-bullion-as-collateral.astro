  .author-name { font: 600 19px/1.3 var(--font-display); color: var(--ink); margin-bottom: 4px; }
  .author-role { font: 500 13px/1.4 var(--font-body); color: #857f6e; margin-bottom: 14px; }
  .author-card p { font: 400 14.5px/1.7 var(--font-body); color: var(--text-soft); margin: 0 0 12px; }
  .author-card p:last-child { margin: 0; }

  .art-cta { background: var(--ink); color: #f1ece1; padding: clamp(64px, 8vw, 104px) var(--section-x); text-align: center; }
  .art-cta-inner { max-width: 680px; margin: 0 auto; }
  .art-cta-h2 { font: 600 clamp(28px, 3.6vw, 44px)/1.12 var(--font-display); letter-spacing: -0.7px; margin: 0 0 18px; text-wrap: balance; }
  .art-cta-lead { font: 400 17px/1.7 var(--font-body); color: var(--text-on-dark-soft); margin: 0 0 34px; }
  .news-cta { background: var(--gold); color: var(--ink-gold-button); border: none; box-shadow: none; }

  @media (max-width: 960px) {
    .toc-rail { display: none; }
    .art-grid { grid-template-columns: 1fr; }
    .checklist { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Reading progress + TOC scroll-spy. Minimal, passive.
  const bar = document.querySelector<HTMLElement>("[data-progress]");
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-toc]"));
  const ids = links.map((l) => l.dataset.toc!).filter(Boolean);
  const sections = ids.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];

  const onScroll = () => {
    if (bar) {
      const h = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = (h > 0 ? Math.min(100, (window.scrollY / h) * 100) : 0) + "%";
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  if ("IntersectionObserver" in window && sections.length) {
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) {
            const id = en.target.id;
            links.forEach((l) => l.classList.toggle("is-active", l.dataset.toc === id));
          }
        });
      },
      { rootMargin: "-110px 0px -65% 0px", threshold: 0 }
    );
    sections.forEach((s) => spy.observe(s));
  }
</script>
