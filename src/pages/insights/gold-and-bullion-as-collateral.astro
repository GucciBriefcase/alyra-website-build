    </div>
  </header>

  <!-- Hero image -->
  <div class="art-hero reveal">
    <div class="art-hero-frame"><Image src={heroImg} alt="Investment-grade gold bullion bars" widths={[480, 768, 1080]} sizes="(max-width: 1120px) 100vw, 1080px" format="webp" quality={72} loading="eager" fetchpriority="high" /></div>
    <p class="art-hero-cap"><span class="cap-rule" aria-hidden="true"></span>A specialist reviews bullion documentation, bar markings and vault records before a collateral assessment.</p>
  </div>

  <!-- Body -->
  <div class="art-wrap">
    <div class="art-grid">
      <aside class="toc-rail">
        <div class="toc-head">On this page</div>
        <nav class="toc-nav" aria-label="Article sections">
