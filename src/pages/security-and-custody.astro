---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, absoluteUrl } from "../config/site";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import TrustStrip from "../components/sections/TrustStrip.astro";
import SecurityCustody from "../components/sections/SecurityCustody.astro";
import Faq from "../components/sections/Faq.astro";
import RequestSection from "../components/sections/RequestSection.astro";

const path = "/security-and-custody/";
const title = "Security & Custody | ALYRA";
const description =
  "How ALYRA protects your asset: documented on arrival, held in secure insured custody for the loan term, and returned once the loan is repaid.";

const custodySteps = [
  { title: "Received and checked", body: "Your asset is received, identified, and reviewed against available documents on arrival." },
  { title: "Photographed and documented", body: "Its condition, details, and supporting records are photographed and documented before custody." },
  { title: "Held securely", body: "The asset is catalogued and held in secure, access-controlled custody for the agreed loan term." },
  { title: "Returned after repayment", body: "Once the loan is repaid under the agreed terms, the asset is returned to you as it was received." },
];

const protections = [
  { icon: "lock", title: "Secure custody", body: "Your asset is held in secure, access-controlled storage for the agreed loan term — never on display, never for sale." },
  { icon: "shield", title: "Insured while held", body: "Insurance may apply while your asset is in custody, subject to policy terms, asset approval, valuation limits and custody conditions." },
  { icon: "doc", title: "Documented condition", body: "Condition and details are photographed and recorded before custody, so your asset is returned in the state it was received." },
  { icon: "eye", title: "Handled in confidence", body: "Your asset is never listed, marketed or sent to auction. Access is restricted and your enquiry stays private throughout." },
];

const faqs = [
  { q: "Where is my asset stored?", a: "Eligible assets are held in secure, access-controlled custody for the agreed loan term. Storage arrangements suit the asset type and are confirmed before you proceed." },
  { q: "Is my asset insured while in custody?", a: "Insurance may apply while your asset is held, subject to policy terms, asset approval, valuation limits and custody conditions. The cover relevant to your asset is explained before custody begins." },
  { q: "Do I keep ownership while ALYRA holds my asset?", a: "Yes. You remain the owner throughout. ALYRA holds the asset only as security for the loan, and returns it once the loan is repaid in accordance with the agreed terms." },
  { q: "What condition will my asset be in when it is returned?", a: "Your asset's condition is documented and photographed before custody, and it is held carefully so it can be returned in the state it was received, subject to normal handling and custody conditions." },
  { q: "Who has access to my asset?", a: "Access is restricted and handled discreetly. Your asset is not displayed, marketed or made available to buyers while it is held as security." },
  { q: "Can I retrieve my asset early?", a: "Early repayment may be available where permitted under your loan terms. Once the loan is repaid, your asset is returned. Any applicable fees and conditions are disclosed before you proceed." },
  { q: "What happens to my asset if I do not repay?", a: "Your asset is at risk if you do not meet your repayment obligations. Fees, notices, redemption rights and enforcement processes are disclosed in your written loan terms before you proceed." },
];

const crumbs = [
  { name: "Home", href: "/" },
  { name: "Security & Custody" },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": absoluteUrl(path) + "#webpage",
    url: absoluteUrl(path),
    name: title,
    description,
    isPartOf: { "@id": absoluteUrl("/") + "#website" },
    inLanguage: "en-AU",
    about: { "@id": absoluteUrl("/") + "#organization" },
  },
];
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <!-- Hero -->
  <header class="sec-hero">
    <div class="container">
      <Breadcrumbs items={crumbs} />
      <div class="sec-hero-inner">
        <p class="eyebrow hin">Security &amp; custody</p>
        <h1 class="sec-h1 hin">Your asset, securely held until <span class="hl">repayment</span>.</h1>
        <p class="sec-lead hin">
          When a loan proceeds, your asset is documented, insured where applicable, and held in secure
          custody for the agreed term — then returned to you once the loan is repaid.
        </p>
        <div class="hin"><a class="btn btn--primary" href={SITE.enquiryPath}>Request a Confidential Valuation</a></div>
        <p class="sec-reassure hin">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          You remain the owner · ALYRA holds your asset only as security
        </p>
      </div>
    </div>
  </header>

  <TrustStrip />

  <!-- What it means -->
  <section class="section section--white reveal">
    <div class="container sec-def">
      <p class="eyebrow">What it means</p>
      <h2 class="sec-def-h2">You keep ownership. We keep it safe.</h2>
      <p class="sec-def-p">Borrowing against an asset should never feel like losing it. With ALYRA, your asset is held only as security for your loan — not listed, not marketed, not sold.</p>
      <p class="sec-def-p">It is documented on arrival, held in secure custody for the agreed term, and returned to you once the loan is repaid under the agreed terms.</p>
      <p class="sec-def-p sec-def-p--em">Securely held. Fully documented. Privately handled.</p>
    </div>
  </section>

  <!-- Custody process (dark timeline) -->
  <SecurityCustody
    lead={[
      "When a loan is approved, your asset is documented on arrival, photographed and held in secure custody for the agreed term. Insurance may apply while it is held, subject to policy terms, asset approval, valuation limits and custody conditions.",
      "You remain the owner throughout. ALYRA holds the asset only as security for the loan.",
    ]}
    steps={custodySteps}
    riskLine="Your asset is at risk if repayment obligations are not met."
  />

  <!-- How we protect your asset -->
  <section class="section reveal">
    <div class="container">
      <div class="prot-head">
        <p class="eyebrow">How we protect your asset</p>
        <h2 class="h2 prot-h2">Secure, insured where applicable, and documented.</h2>
        <p class="lead prot-intro">Every safeguard exists so you can access funds with confidence and recover your asset at the end of the loan.</p>
      </div>
      <div class="prot-grid">
        {protections.map((p) => (
          <div class="prot-card">
            <div class="prot-icon" aria-hidden="true">
              {p.icon === "lock" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              )}
              {p.icon === "shield" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
              )}
              {p.icon === "doc" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><path d="m9 15 2 2 4-4"></path></svg>
              )}
              {p.icon === "eye" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 10 8 10 8a13.2 13.2 0 0 1-1.67 2.68"></path><path d="M6.61 6.61A13.5 13.5 0 0 0 2 12s3 8 10 8a9.7 9.7 0 0 0 5.39-1.61"></path><line x1="2" y1="2" x2="22" y2="22"></line></svg>
              )}
            </div>
            <h3 class="prot-card-title">{p.title}</h3>
            <p class="prot-card-body">{p.body}</p>
          </div>
        ))}
      </div>
      <p class="prot-note">Insurance, storage and custody arrangements depend on the asset and are confirmed in writing before custody begins. Your asset is at risk if repayment obligations are not met.</p>
    </div>
  </section>

  <!-- FAQ -->
  <Faq
    faqs={faqs}
    heading="Security &amp; custody questions."
    intro="Everything else is explained privately before you proceed. Speak with a specialist about your asset in confidence."
    group="security-faq"
  />

  <!-- Request -->
  <RequestSection noun="asset" idPrefix="security" />
</BaseLayout>

<style>
  .sec-hero { background: var(--cream); color: var(--ink); padding: calc(var(--nav-offset) + 24px) var(--section-x) 0; border-bottom: 1px solid var(--gold); }
  .sec-hero-inner { max-width: 820px; margin-left: auto; margin-right: auto; text-align: center; padding: clamp(40px, 7vh, 80px) 0 clamp(44px, 7vh, 84px); }
  .sec-h1 { font: 600 clamp(38px, 5vw, 62px)/1.05 var(--font-display); letter-spacing: -1.4px; margin: 0 auto 22px; text-wrap: balance; }
  .sec-h1 .hl { color: var(--gold-fg); }
  .sec-lead { font: 400 clamp(16px, 1.4vw, 19px)/1.7 var(--font-body); color: var(--text-muted); max-width: 600px; margin: 0 auto 30px; }
  .sec-reassure { display: flex; align-items: center; justify-content: center; gap: 9px; font: 400 13px/1.6 var(--font-body); color: #6e6d65; margin-top: 18px; letter-spacing: .2px; }
  .sec-reassure svg { flex: none; opacity: .75; }

  @keyframes hin-rise { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }
  /* H1 rises without fading: an invisible headline delays LCP until the animation reveals it. */
  @keyframes hin-rise-solid { from { transform: translateY(16px); } to { transform: none; } }
  .hin { animation: hin-rise .65s cubic-bezier(.2,.7,.2,1) backwards; }
  .eyebrow.hin { animation-delay: .08s; }
  .sec-h1.hin { animation-name: hin-rise-solid; animation-delay: .17s; }
  .sec-lead.hin { animation-delay: .26s; }

  .sec-def { max-width: 820px; margin: 0 auto; text-align: center; }
  .sec-def-h2 { font: 600 clamp(28px, 3.6vw, 44px)/1.12 var(--font-display); letter-spacing: -0.8px; margin: 0 0 22px; text-wrap: balance; }
  .sec-def-p { font: 400 17px/1.8 var(--font-body); color: var(--text-muted); margin: 0 auto 14px; max-width: 620px; }
  .sec-def-p--em { font: 500 18px/1.5 var(--font-display); color: var(--ink); letter-spacing: -0.2px; margin-top: 22px; }

  .prot-head { max-width: 680px; margin-bottom: 48px; }
  .prot-intro { color: var(--text-soft); max-width: 600px; }
  .prot-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 34px; }
  .prot-icon { width: 38px; height: 38px; border: 1px solid #c9bfa6; border-radius: 9px; margin-bottom: 18px; display: flex; align-items: center; justify-content: center; color: var(--gold-fg); }
  .prot-card-title { font: 600 17px/1.3 var(--font-display); margin: 0 0 9px; }
  .prot-card-body { font: 400 14px/1.65 var(--font-body); color: var(--text-soft); margin: 0; }
  .prot-note { font: 400 12.5px/1.6 var(--font-body); color: #9a937f; margin: 40px 0 0; max-width: 760px; }
</style>
