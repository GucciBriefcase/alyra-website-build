---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Page not found | ALYRA";
const description =
  "The page you were looking for doesn't exist or has moved. Explore ALYRA's asset loans, insights and confidential valuation service.";
---

<BaseLayout title={title} description={description} path="/404/">
  <section class="nf">
    <div class="nf-inner">
      <p class="eyebrow">Error 404</p>
      <h1 class="nf-h1">This page doesn't exist.</h1>
      <p class="nf-lead">
        The address may have been typed incorrectly, or the page may have moved.
        Everything ALYRA offers is one step from here.
      </p>
      <div class="nf-actions">
        <a class="btn" href="/">Back to home</a>
        <a class="nf-link" href="/loans/">Asset loans <span class="arrow">→</span></a>
        <a class="nf-link" href="/insights/">Insights <span class="arrow">→</span></a>
        <a class="nf-link" href="/valuation/">Request a valuation <span class="arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { padding: calc(var(--nav-offset) + 96px) var(--section-x) 140px; text-align: center; }
  .nf-inner { max-width: 560px; margin: 0 auto; }
  .nf-h1 { font: 600 clamp(34px, 5vw, 54px)/1.1 var(--font-display); letter-spacing: -1.2px; margin: 14px 0 18px; }
  .nf-lead { font: 400 17px/1.7 var(--font-body); color: var(--text-muted); margin: 0 0 36px; }
  .nf-actions { display: flex; flex-direction: column; align-items: center; gap: 18px; }
  .nf-link { font: 600 14px/1 var(--font-body); color: var(--gold-ink); text-decoration: none; }
  .nf-link:hover { color: var(--ink); }
</style>
