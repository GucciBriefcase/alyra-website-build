---
/**
 * Base page layout: HTML shell, font loading, site-wide structured data
 * (Organisation + WebSite), shared Nav and Footer. Page-specific metadata and
 * schema are passed in as props.
 */
import "../styles/global.css";
import { SITE, absoluteUrl } from "../config/site";
import Seo from "../components/Seo.astro";
import JsonLd from "../components/JsonLd.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import MobileCta from "../components/MobileCta.astro";

interface Props {
  title: string;
  description: string;
  path: string;
  image?: string;
  imageAlt?: string;
  ogType?: "website" | "article";
  /** Additional page-specific JSON-LD (Service, FAQPage, WebPage, etc.). */
  schema?: Record<string, unknown> | Record<string, unknown>[];
  /** Hide the mobile sticky CTA (e.g. on the valuation page). */
  hideMobileCta?: boolean;
}

const { title, description, path, image, imageAlt, ogType, schema, hideMobileCta } = Astro.props;

const sameAs = Object.values(SITE.social).filter(Boolean);

// Analytics / verification (inert until IDs are set in site.ts).
const { gtmId, googleSiteVerification, bingSiteVerification } = SITE.analytics;
const gtmHeadScript = `(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${gtmId}');`;
const gtmBodyNoscript = `<iframe src="https://www.googletagmanager.com/ns.html?id=${gtmId}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`;

// Site-wide Organisation (FinancialService) + WebSite structured data.
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "FinancialService",
  "@id": absoluteUrl("/") + "#organization",
  name: SITE.name,
  alternateName: "ALYRA Private Lending",
  legalName: SITE.legalEntity,
  identifier: { "@type": "PropertyValue", propertyID: "ABN", value: SITE.abn },
  hasCredential: [
    {
      "@type": "EducationalOccupationalCredential",
      credentialCategory: "licence",
      name: `Pawnbroker licence ${SITE.pawnbrokerLicence} (${SITE.pawnbrokerLicenceJurisdiction})`,
    },
    {
      "@type": "EducationalOccupationalCredential",
      credentialCategory: "licence",
      name: `Second-hand dealer licence ${SITE.secondHandDealerRegistration} (${SITE.secondHandDealerJurisdiction})`,
    },
  ],
  url: absoluteUrl("/"),
  logo: absoluteUrl("/assets/alyra-logo-ink.png"),
  image: absoluteUrl(SITE.defaultOgImage),
  description: SITE.entityDescription,
  email: SITE.email,
  ...(SITE.phone ? { telephone: SITE.phone } : {}),
  priceRange: "$50,000 - $5,000,000",
  currenciesAccepted: SITE.currency,
  areaServed: SITE.locationsServed.map((name) => ({ "@type": "City", name })),
  address: { "@type": "PostalAddress", addressCountry: SITE.serviceAreaCode },
  knowsAbout: [
    "Asset-based lending",
    "Pawnbroking",
    "Luxury watch valuation",
    "Jewellery and diamond valuation",
    "Fine art lending",
    "Classic car finance",
    "Gold bullion",
  ],
  slogan: SITE.tagline,
  ...(sameAs.length ? { sameAs } : {}),
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": absoluteUrl("/") + "#website",
  url: absoluteUrl("/"),
  name: SITE.name,
  publisher: { "@id": absoluteUrl("/") + "#organization" },
  inLanguage: "en-AU",
};
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Google Tag Manager — hosts GA4 + Microsoft Clarity tags. */}
    {gtmId && <script is:inline set:html={gtmHeadScript} />}
    {/* Webmaster verification (fallback to verifying via GTM/GA). */}
    {googleSiteVerification && (
      <meta name="google-site-verification" content={googleSiteVerification} />
    )}
    {bingSiteVerification && <meta name="msvalidate.01" content={bingSiteVerification} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fonts are self-hosted (see global.css @font-face). Preload the two
         critical files: Poppins 600 renders every H1 (the LCP element) and
         Inter covers body text. crossorigin is required on font preloads. -->
    <link rel="preload" href="/fonts/poppins-600-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />

    <Seo
      title={title}
      description={description}
      path={path}
      image={image}
      imageAlt={imageAlt}
      ogType={ogType}
    />

    <JsonLd schema={[orgSchema, websiteSchema]} />
    {schema && <JsonLd schema={schema} />}
  </head>

  <body>
    {/* Google Tag Manager (noscript) — must be immediately after <body>. */}
    {gtmId && <noscript set:html={gtmBodyNoscript} />}
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <MobileCta hidden={hideMobileCta} />

    <script>
      // Progressive-enhancement scroll reveal. Sections marked `.reveal` fade up
      // once on entry; under prefers-reduced-motion they are shown immediately
      // (handled in CSS). One-shot via IntersectionObserver.
      const root = document.body;
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const els = document.querySelectorAll<HTMLElement>(".reveal");
      if (!reduce && "IntersectionObserver" in window && els.length) {
        root.classList.add("reveal-on");
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((en) => {
              if (en.isIntersecting) {
                en.target.classList.add("in");
                io.unobserve(en.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.08 }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 100;
    background: var(--ink);
    color: var(--cream);
    padding: 12px 18px;
    border-radius: 0 0 8px 0;
    font: 600 14px/1 var(--font-body);
    text-decoration: none;
  }
  .skip-link:focus { left: 0; }
</style>
