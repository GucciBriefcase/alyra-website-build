---
/**
 * "More from Insights" — related-article cards shown at the foot of each
 * article, above the final CTA.
 *
 * Selection is automatic and derived from src/data/insights.ts. Every published
 * article (one with a real page at /insights/<slug>/) is laid out in a stable
 * ring; for the current article we take the next three around that ring. That
 * guarantees each article links OUT to three others AND is linked TO by exactly
 * three others — no orphans, no hand-editing body copy. Same-category articles
 * are then surfaced first for editorial relevance (the sort is stable, so ring
 * order is preserved within each group).
 */
import { Image } from "astro:assets";
import { FEATURED, POSTS } from "../data/insights";
import type { InsightCard } from "../data/insights";

interface Props {
  /** Slug of the current article — excluded from the list. */
  slug: string;
  /** Optional heading override. */
  heading?: string;
}

const { slug, heading = "More from Insights" } = Astro.props;

type Published = InsightCard & { slug: string };

// Featured first, then index order — a stable ring independent of publish date.
const published: Published[] = [
  FEATURED,
  ...POSTS.filter((p): p is Published => Boolean(p.slug)),
];

const current = published.findIndex((a) => a.slug === slug);

const COUNT = 3;
let related: Published[] = [];
if (current !== -1 && published.length > 1) {
  for (let k = 1; related.length < COUNT && k < published.length; k++) {
    related.push(published[(current + k) % published.length]);
  }
  const cat = published[current].category;
  related.sort((a, b) => Number(b.category === cat) - Number(a.category === cat));
}
---

{related.length > 0 && (
  <section class="rel reveal" aria-labelledby="rel-heading">
    <div class="rel-inner">
      <div class="rel-head">
        <h2 id="rel-heading" class="rel-h2">{heading}</h2>
        <a class="rel-all" href="/insights/">All insights <span aria-hidden="true">→</span></a>
      </div>
      <div class="rel-grid">
        {related.map((post) => (
          <a href={`/insights/${post.slug}/`} class="rel-card">
            <div class="rel-img">
              <Image src={post.image} alt={post.imageAlt} widths={[300, 460, 600]} sizes="(max-width: 640px) 90vw, 340px" format="webp" quality={70} loading="lazy" />
            </div>
            <div class="rel-body">
              <div class="rel-cat">{post.category}</div>
              <h3 class="rel-title">{post.title}</h3>
              <div class="rel-meta">
                <span>{post.readTime}</span>
                <span class="rel-read">Read <span aria-hidden="true">→</span></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .rel {
    background: var(--cream);
    border-top: 1px solid var(--border);
    padding: clamp(48px, 6vw, 80px) var(--section-x);
  }
  .rel-inner { max-width: 1100px; margin: 0 auto; }
  .rel-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 20px; flex-wrap: wrap; margin-bottom: 28px;
  }
  .rel-h2 {
    font: 600 clamp(22px, 2.4vw, 30px)/1.15 var(--font-display);
    letter-spacing: -0.5px; margin: 0; text-wrap: balance;
  }
  .rel-all {
    font: 600 13px/1 var(--font-body); color: var(--gold-ink);
    text-decoration: none; white-space: nowrap;
    border-bottom: 1px solid transparent; padding-bottom: 3px;
    transition: border-color .2s ease;
  }
  .rel-all:hover { border-color: currentColor; }

  .rel-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .rel-card {
    display: flex; flex-direction: column;
    text-decoration: none; color: inherit;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 3px; overflow: hidden;
    transition: transform .28s ease, border-color .28s ease, box-shadow .28s ease;
  }
  .rel-card:hover { transform: translateY(-4px); border-color: var(--gold); box-shadow: 0 14px 32px rgba(40,38,30,.12); }
  .rel-img { overflow: hidden; }
  .rel-img img { display: block; width: 100%; height: 168px; object-fit: cover; transition: transform .7s ease; }
  .rel-card:hover .rel-img img { transform: scale(1.04); }
  .rel-body { padding: 20px 20px 22px; display: flex; flex-direction: column; flex: 1; }
  .rel-cat { font: 600 11px/1 var(--font-body); letter-spacing: 2px; text-transform: uppercase; color: var(--gold-ink); margin-bottom: 12px; }
  .rel-title { font: 600 17px/1.3 var(--font-display); letter-spacing: -0.2px; margin: 0 0 16px; text-wrap: balance; }
  .rel-meta { margin-top: auto; display: flex; align-items: center; gap: 12px; font: 500 12.5px/1 var(--font-body); color: #9a937f; }
  .rel-read { margin-left: auto; font: 600 12.5px/1 var(--font-body); color: var(--gold-ink); white-space: nowrap; }

  @media (max-width: 1040px) { .rel-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .rel-grid { grid-template-columns: 1fr; gap: 16px; } }
</style>
