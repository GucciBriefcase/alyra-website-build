---
/**
 * Dark "Security & custody" section: copy on the left, a 4-step custody timeline
 * on the right (final step marked complete with a tick). Callers pass the lead
 * paragraphs and timeline steps so wording can be asset-specific.
 */
interface TimelineStep {
  title: string;
  body: string;
}
interface Props {
  id?: string;
  lead: string[];
  steps: TimelineStep[];
  riskLine?: string;
  /** When true, the final step is a gold check (homepage). Asset pages number it. */
  tickLast?: boolean;
}
const { id = "security", lead, steps, riskLine, tickLast = false } = Astro.props;
---

<section id={id} class="section section--dark reveal">
  <div class="container sc-grid">
    <div>
      <p class="eyebrow eyebrow--on-dark">Security &amp; custody</p>
      <h2 class="sc-h2">Securely held until repayment.</h2>
      {lead.map((p) => <p class="sc-lead">{p}</p>)}
      {riskLine && <p class="sc-risk">{riskLine}</p>}
    </div>

    <div>
      <p class="sc-timeline-label">Custody process</p>
      <ol class="sc-timeline">
        <span class="sc-line" aria-hidden="true"></span>
        {steps.map((s, i) => {
          const done = tickLast && i === steps.length - 1;
          return (
            <li class="sc-step">
              <div class:list={["sc-dot", { "sc-dot--done": done }]}>
                {done ? (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1b1a16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
                ) : (
                  i + 1
                )}
              </div>
              <div class="sc-step-body">
                <div class="sc-step-title">{s.title}</div>
                <div class="sc-step-text">{s.body}</div>
              </div>
            </li>
          );
        })}
      </ol>
    </div>
  </div>
</section>

<style>
  .sc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: clamp(40px, 6vw, 80px);
    align-items: start;
  }
  .sc-h2 {
    font: 600 clamp(28px, 3.4vw, 40px)/1.1 var(--font-display);
    letter-spacing: -0.6px;
    color: var(--cream);
    margin: 0 0 20px;
  }
  .sc-lead { font: 400 16px/1.75 var(--font-body); color: var(--text-on-dark-soft); margin: 0 0 18px; }
  .sc-risk { font: 400 13px/1.6 var(--font-body); color: var(--error-on-dark); margin: 10px 0 0; }

  .sc-timeline-label {
    font: 600 11px/1 var(--font-body);
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 28px;
  }
  .sc-timeline { list-style: none; margin: 0; padding: 0; position: relative; }
  .sc-line {
    position: absolute;
    left: 21px; top: 21px; bottom: 21px;
    width: 1px;
    background: linear-gradient(180deg, rgba(196,165,103,.55), rgba(196,165,103,.18));
    z-index: 0;
  }
  .sc-step { display: flex; gap: 18px; position: relative; z-index: 1; padding-bottom: 30px; }
  .sc-step:last-child { padding-bottom: 0; }
  .sc-dot {
    width: 42px; height: 42px;
    border-radius: 50%;
    border: 1px solid rgba(196, 165, 103, .55);
    background: var(--ink);
    display: flex; align-items: center; justify-content: center;
    flex: none;
    font: 600 15px/1 var(--font-display);
    color: var(--gold);
  }
  .sc-dot--done { background: var(--gold); border-color: var(--gold); }
  .sc-step-body { padding-top: 3px; }
  .sc-step-title { font: 600 16px/1.3 var(--font-display); color: #f1ece1; margin-bottom: 5px; }
  .sc-step-text { font: 400 13.5px/1.6 var(--font-body); color: var(--text-muted-on-dark); }
</style>
