---
/**
 * Specialist bio card (Eden John). Reused on the homepage valuation section and
 * on each asset page. Optional credential tags and an optional second paragraph.
 */
import { Image } from "astro:assets";
import { SITE } from "../../config/site";
import specialistImg from "../../assets/images/specialist.jpg";

interface Props {
  /** Optional credential chips (shown on the homepage). */
  tags?: string[];
  /** Override the second paragraph (asset pages use a shorter line). */
  secondLine?: string;
}
const {
  tags = [],
  secondLine = "Clients deal confidentially from first enquiry through assessment, documentation, custody, and loan completion.",
} = Astro.props;
---

<div class="spec-card">
  <Image
    src={specialistImg}
    alt="Eden John, Principal Valuation Specialist"
    widths={[96, 192]}
    sizes="96px"
    format="webp"
    quality={80}
    loading="lazy"
    class="spec-photo"
  />
  <div>
    <div class="spec-name">Eden John</div>
    <div class="spec-role">Principal Valuation Specialist</div>
    <p class="spec-bio">
      Eden John leads ALYRA's valuation process, with experience across high-value watches,
      jewellery, diamonds, and collectible assets for private clients.
    </p>
    <p class="spec-bio">{secondLine}</p>
    <a href={SITE.enquiryPath} class="arrow-link spec-link">
      Speak With a Specialist <span class="arrow">→</span>
    </a>
    {tags.length > 0 && (
      <div class="spec-tags">
        {tags.map((t) => <span class="spec-tag">{t}</span>)}
      </div>
    )}
  </div>
</div>

<style>
  .spec-card {
    max-width: 780px;
    margin: 0 auto;
    display: flex;
    gap: 26px;
    align-items: flex-start;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: clamp(24px, 3vw, 34px);
  }
  .spec-photo { width: 92px; height: 92px; flex: none; object-fit: cover; object-position: center 22%; border-radius: 50%; }
  .spec-name { font: 600 18px/1.3 var(--font-display); color: var(--ink); margin: 0 0 1px; }
  .spec-role { font: 500 13px/1.4 var(--font-body); color: var(--gold-fg); margin-bottom: 14px; }
  .spec-bio { font: 400 14.5px/1.7 var(--font-body); color: var(--text-muted); margin: 0 0 12px; }
  .spec-link {
    font: 600 13.5px/1 var(--font-body);
    color: var(--ink);
    border-bottom: 1px solid #c9bfa6;
    padding-bottom: 4px;
  }
  .spec-tags { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 18px; }
  .spec-tag {
    font: 500 11.5px/1 var(--font-body);
    color: #857f6e;
    border: 1px solid #e7e1d4;
    border-radius: 6px;
    padding: 6px 10px;
  }
  @media (max-width: 520px) { .spec-card { flex-direction: column; } }
</style>
