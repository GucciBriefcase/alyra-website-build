---
/**
 * Standardised site footer (one variant for every page, per the handoff).
 * Brand + link columns → licence/entity cards → disclaimer → bottom legal →
 * SkyScale attribution. All entity data comes from SITE config.
 */
import { SITE } from "../config/site";
import { ASSETS } from "../data/assets";
import Logo from "./Logo.astro";

const year = new Date().getFullYear();
const companyLinks = [
  { label: "About", href: "/about/" },
  { label: "How it works", href: "/how-it-works/" },
  { label: "Our specialist", href: "/#valuation" },
  { label: "Locations", href: "/contact/" },
  { label: "FAQ", href: "/#faq" },
];
const legalLinks = [
  { label: "Privacy", href: "/privacy/" },
  { label: "Terms", href: "/terms/" },
  { label: "Complaints", href: "/complaints/" },
];
const entityCards = [
  {
    label: "Legal entity",
    value: SITE.legalEntity,
    sub: `ABN ${SITE.abn}`,
  },
  {
    label: "Pawnbroker licence",
    value: SITE.pawnbrokerLicence,
    sub: SITE.pawnbrokerLicenceJurisdiction,
  },
  {
    label: "Second-hand dealer licence",
    value: SITE.secondHandDealerRegistration,
    sub: SITE.secondHandDealerJurisdiction,
  },
];
const att = SITE.attribution;
---

<footer class="footer">
  <div class="container">
    <!-- Brand + link columns -->
    <div class="footer-cols">
      <div class="footer-brand">
        <span class="footer-logo"><Logo height={26} /></span>
        <p class="footer-blurb">
          Discreet asset-based lending for private clients. Borrow against
          luxury watches, jewellery, art, cars, designer handbags, and gold bullion.
        </p>
      </div>

      <div class="footer-col">
        <div class="col-head">Asset Loans</div>
        <div class="col-links">
          {ASSETS.map((a) => (
            <a class="foot-link" href={`/loans/${a.slug}/`}>{a.breadcrumbName}</a>
          ))}
        </div>
      </div>

      <div class="footer-col">
        <div class="col-head">Company</div>
        <div class="col-links">
          {companyLinks.map((l) => <a class="foot-link" href={l.href}>{l.label}</a>)}
        </div>
      </div>

      <div class="footer-col">
        <div class="col-head">Contact</div>
        <div class="col-links col-links--contact">
          <span class="foot-row">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m2 7 10 6 10-6"></path></svg>
            <a class="foot-link" href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </span>
          <span class="foot-row">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>
            <span class="foot-muted">By appointment only</span>
          </span>
          <a class="foot-cta" href={SITE.enquiryPath}>Request a valuation <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </div>

    <!-- Entity / licence cards -->
    <div class="footer-cards">
      {entityCards.map((c) => (
        <div class="footer-card">
          <div class="footer-card-label">{c.label}</div>
          <div class="footer-card-value">{c.value}</div>
          <div class="footer-card-sub">{c.sub}</div>
        </div>
      ))}
    </div>

    <!-- Disclaimer -->
    <p class="footer-disclaimer">{SITE.footerDisclaimer}</p>

    <!-- Bottom legal -->
    <div class="footer-bottom">
      <span>© {year} {SITE.brand}. All rights reserved.</span>
      <span class="footer-legal-links">
        {legalLinks.map((l, i) => (
          <>
            {i > 0 && <span aria-hidden="true" class="dot">·</span>}
            <a class="foot-link" href={l.href}>{l.label}</a>
          </>
        ))}
      </span>
    </div>

    <!-- Attribution -->
    <div class="footer-attr">
      <a
        class="ss-by"
        href={att.url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${att.label} ${att.name}`}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="9"></circle>
          <path d="M3 12h18"></path>
          <path d="M12 3c2.5 2.6 2.5 15.4 0 18"></path>
          <path d="M12 3c-2.5 2.6-2.5 15.4 0 18"></path>
        </svg>
        <span>{att.label}</span>
        <span aria-hidden="true" class="ss-divider"></span>
        <span class="ss-logo">
          <img src="/assets/skyscale-logo.svg" alt={att.name} height="22" />
          <span aria-hidden="true" class="ss-wipe">
            <span class="ss-wipe-fill"></span>
          </span>
        </span>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink-deep);
    color: #a39d8e;
    padding: clamp(56px, 6vw, 80px) var(--section-x) 40px;
    /* Same gold rule as .section--rule-gold, so the footer divider matches
       the section dividers used across the page. */
    border-top: 1px solid var(--gold);
  }
  .foot-link { color: var(--text-muted-on-dark); transition: color .25s ease; text-decoration: none; }
  .foot-link:hover { color: var(--text-on-dark); }

  .footer-cols {
    display: grid;
    grid-template-columns: 1.3fr 1fr 0.9fr 1.1fr;
    gap: 40px;
    padding-bottom: 46px;
  }
  .footer-col { border-left: 1px solid var(--border-dark); padding-left: 40px; }
  .footer-logo { display: block; line-height: 0; color: var(--cream); margin-bottom: 20px; }
  .footer-blurb { font: 400 14px/1.7 var(--font-body); color: #a39d8e; margin: 0; max-width: 300px; }
  .foot-muted { color: #a39d8e; font: 400 14px/1.3 var(--font-body); }
  .col-head {
    font: 600 12px/1 var(--font-body);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 18px;
  }
  .col-links { display: flex; flex-direction: column; gap: 12px; font: 400 14px/1.3 var(--font-body); }
  .foot-row { display: flex; align-items: center; gap: 9px; }
  .foot-row svg { flex: none; color: var(--gold); opacity: .85; }
  .foot-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    margin-top: 8px;
    padding: 12px 18px;
    border: 1px solid var(--border-dark);
    border-radius: var(--radius-control);
    font: 500 14px/1 var(--font-body);
    color: var(--gold);
    text-decoration: none;
    transition: color .25s ease, border-color .25s ease;
  }
  .foot-cta:hover { color: var(--text-on-dark); border-color: var(--gold); }

  .footer-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    padding: 32px 0;
    border-top: 1px solid var(--border-dark);
  }
  .footer-card {
    border: 1px solid var(--border-dark);
    border-radius: var(--radius-control);
    padding: 17px 20px;
    background: rgba(255, 255, 255, .015);
  }
  .footer-card-label {
    font: 600 10px/1.4 var(--font-body);
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 9px;
  }
  .footer-card-value { font: 600 15px/1.4 var(--font-body); color: var(--text-on-dark); }
  .footer-card-sub { font: 400 13px/1.5 var(--font-body); color: #a39d8e; margin-top: 2px; }

  .footer-disclaimer {
    font: 400 13px/1.7 var(--font-body);
    color: #a39d8e;
    margin: 0;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border-dark);
    max-width: 960px;
  }

  .footer-bottom {
    padding-top: 26px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    font: 400 13px/1.6 var(--font-body);
    color: #837e71;
  }
  .footer-legal-links { display: inline-flex; align-items: center; gap: 8px; }
  .footer-legal-links .dot { color: #837e71; }

  .footer-attr { margin-top: 40px; display: flex; justify-content: center; }
  .ss-by {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    border: 1px solid rgba(241,236,225,.18);
    border-radius: var(--radius-control);
    padding: 13px 30px;
    text-decoration: none;
    font: 400 15px/1 var(--font-body);
    color: rgba(241,236,225,.85);
    transition: color .2s ease, border-color .2s ease;
  }
  .ss-by:hover { color: #f1ece1; border-color: rgba(241,236,225,.4); }
  .ss-by svg { opacity: .7; flex: none; }
  .ss-divider { width: 1px; height: 22px; background: rgba(241,236,225,.2); flex: none; }
  .ss-logo { position: relative; display: inline-flex; align-items: center; flex: none; }
  .ss-logo img { height: 22px; width: auto; display: block; }
  .ss-wipe { position: absolute; inset: 0; overflow: hidden; width: 0; transition: width .5s ease-out; }
  .ss-by:hover .ss-wipe { width: 100%; }
  .ss-wipe-fill {
    display: block;
    height: 22px;
    width: 127px;
    background: #6ae1c9;
    -webkit-mask: url(/assets/skyscale-logo.svg) left center/auto 100% no-repeat;
    mask: url(/assets/skyscale-logo.svg) left center/auto 100% no-repeat;
  }

  @media (max-width: 960px) {
    .footer-cols { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
    .footer-col { border-left: 0; padding-left: 0; }
    .footer-cards { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .footer-cols { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
