---
/**
 * Site navigation. Fixed and transparent over the hero; switches to the dark
 * scroll-state after 40px (handled by a CSS class toggle in a tiny inline
 * script). Collapses to a toggleable menu below 1040px.
 */
import { SITE } from "../config/site";
import { ASSETS } from "../data/assets";
import Logo from "./Logo.astro";

const assetLinks = ASSETS.map((a) => ({ label: a.breadcrumbName, href: `/loans/${a.slug}/` }));
const links = [
  { label: "How it Works", href: "/how-it-works/" },
  { label: "Valuation", href: SITE.enquiryPath },
  { label: "Security & Custody", href: "/security-and-custody/" },
  { label: "Insights", href: "/insights/" },
];
const cta = { label: "Request a Confidential Valuation", href: SITE.enquiryPath };
---

<nav class="alyra-nav" data-nav aria-label="Primary">
  <div class="nav-inner container">
    <a href="/" class="nav-logo" aria-label={`${SITE.brand} home`}>
      <Logo height={20} />
    </a>

    <div class="nav-links">
      <div class="nav-item">
        <a href="/#assets" class="nav-trigger" aria-haspopup="menu">
          Assets
          <svg class="nav-caret" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </a>
        <div class="nav-menu" role="menu">
          <div class="nav-menu-card">
            {assetLinks.map((l) => <a role="menuitem" href={l.href}>{l.label}</a>)}
          </div>
        </div>
      </div>
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>

    <div class="nav-actions">
      <a class="nav-cta btn" href={cta.href}>{cta.label}</a>
      <a class="nav-cta-mobile" href={cta.href}>Enquire</a>
      <button
        class="nav-burger"
        data-burger
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" data-menu hidden>
    <span class="mobile-group-label">Assets</span>
    {assetLinks.map((l) => <a href={l.href} data-menu-link class="mobile-sub">{l.label}</a>)}
    {links.map((l) => <a href={l.href} data-menu-link>{l.label}</a>)}
    <a href={cta.href} class="mobile-cta" data-menu-link>{cta.label}</a>
  </div>
</nav>

<style>
  .alyra-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 22px var(--section-x);
    background: transparent;
    transition: background .3s ease, box-shadow .3s ease, padding .25s ease;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
  }
  .nav-logo { display: block; line-height: 0; color: var(--ink); transition: color .3s ease, opacity .3s ease; }
  .nav-logo:hover { opacity: .72; }

  .nav-links {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 30px;
    font: 500 14px/1 var(--font-body);
  }
  .nav-links > a, .nav-trigger {
    color: #3a372f;
    text-decoration: none;
    cursor: pointer;
    transition: color .3s ease, transform .3s cubic-bezier(.2,.7,.2,1);
  }
  .nav-links > a:hover, .nav-trigger:hover { color: var(--gold-fg); transform: translateY(-3px); }

  /* ---- Assets dropdown ---- */
  .nav-item { position: relative; display: inline-flex; align-items: center; }
  .nav-trigger { display: inline-flex; align-items: center; gap: 5px; }
  .nav-caret { transition: transform .25s ease; opacity: .8; }
  .nav-item:hover .nav-caret, .nav-item:focus-within .nav-caret { transform: rotate(180deg); }

  .nav-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    padding-top: 14px; /* transparent bridge so hover doesn't drop in the gap */
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity .2s ease, transform .2s ease;
  }
  .nav-item:hover .nav-menu,
  .nav-item:focus-within .nav-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  .nav-menu-card {
    background: var(--surface-white);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 18px 40px rgba(40, 38, 30, .16);
    padding: 8px;
    min-width: 240px;
    display: flex;
    flex-direction: column;
  }
  .nav-menu-card a {
    display: block;
    padding: 10px 14px;
    border-radius: 8px;
    font: 500 14px/1.3 var(--font-body);
    color: var(--ink);
    text-decoration: none;
    white-space: nowrap;
    transition: background .18s ease, color .18s ease;
  }
  .nav-menu-card a:hover { background: rgba(196, 165, 103, .14); color: var(--gold-ink); }

  .nav-cta {
    font: 600 13px/1 var(--font-body);
    letter-spacing: .3px;
    padding: 12px 22px;
    border-radius: var(--radius-control);
    color: #f1ece1;
    white-space: nowrap;
    background: var(--ink);
    box-shadow: none;
  }
  .nav-cta:hover { color: var(--ink); transform: translateY(-1.5px); box-shadow: 0 8px 22px rgba(120,124,130,.4); }

  .nav-actions { display: flex; align-items: center; gap: 12px; }

  .nav-cta-mobile {
    display: none;
    font: 600 12.5px/1 var(--font-body);
    color: #f1ece1;
    background: var(--ink);
    padding: 11px 18px;
    border-radius: 7px;
    text-decoration: none;
    white-space: nowrap;
    transition: background .3s ease, color .3s ease;
  }

  .nav-burger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    border: none; background: none; cursor: pointer;
    color: var(--ink); padding: 0;
    transition: color .3s ease;
  }

  /* ---- Scrolled state ---- */
  .alyra-nav.is-scrolled {
    background: var(--ink);
    padding: 14px var(--section-x);
    box-shadow: 0 1px 0 rgba(241,236,225,.08), 0 10px 30px rgba(0,0,0,.28);
  }
  .alyra-nav.is-scrolled .nav-logo { color: var(--cream); }
  .alyra-nav.is-scrolled .nav-links > a,
  .alyra-nav.is-scrolled .nav-trigger { color: #cfc8b9; }
  .alyra-nav.is-scrolled .nav-links > a:hover,
  .alyra-nav.is-scrolled .nav-trigger:hover { color: #fff; }
  .alyra-nav.is-scrolled .nav-burger { color: #f1ece1; }
  .alyra-nav.is-scrolled .nav-cta { background: var(--gold); color: var(--ink-gold-button); }
  .alyra-nav.is-scrolled .nav-cta-mobile { background: var(--gold); color: var(--ink-gold-button); }

  /* ---- Mobile menu ---- */
  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 6px;
    max-width: var(--maxw);
    margin: 14px auto 0;
    padding: 16px;
    background: var(--ink);
    border-radius: var(--radius-card);
  }
  .mobile-menu[data-open] { display: flex; }
  .mobile-menu a {
    font: 600 15px/1 var(--font-body);
    color: var(--text-on-dark);
    text-decoration: none;
    padding: 13px 14px;
    border-radius: var(--radius-control);
  }
  .mobile-menu a:hover { background: rgba(255,255,255,.06); }
  .mobile-group-label {
    font: 600 11px/1 var(--font-body);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--gold);
    padding: 8px 14px 4px;
  }
  .mobile-menu .mobile-sub {
    padding-left: 26px;
    font-weight: 500;
    color: var(--text-muted-on-dark);
  }
  .mobile-menu .mobile-cta {
    color: var(--ink);
    background: var(--gold);
    text-align: center;
    padding: 14px;
    margin-top: 4px;
  }
  .mobile-menu .mobile-cta:hover { background: var(--gold-light); }

  @media (max-width: 1040px) {
    .nav-links, .nav-cta { display: none !important; }
    .nav-cta-mobile { display: inline-block; }
    .nav-burger { display: inline-flex; }
  }
</style>

<script>
  // Scroll-state toggle (passive) + mobile menu. Minimal, no dependencies.
  const nav = document.querySelector<HTMLElement>("[data-nav]");
  if (nav) {
    const onScroll = () => {
      const scrolled = (window.scrollY || window.pageYOffset || 0) > 40;
      nav.classList.toggle("is-scrolled", scrolled);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    const burger = nav.querySelector<HTMLButtonElement>("[data-burger]");
    const menu = nav.querySelector<HTMLElement>("[data-menu]");
    if (burger && menu) {
      const close = () => {
        menu.removeAttribute("data-open");
        menu.hidden = true;
        burger.setAttribute("aria-expanded", "false");
      };
      burger.addEventListener("click", () => {
        const open = menu.hasAttribute("data-open");
        if (open) {
          close();
        } else {
          menu.hidden = false;
          menu.setAttribute("data-open", "");
          burger.setAttribute("aria-expanded", "true");
        }
      });
      menu
        .querySelectorAll("[data-menu-link]")
        .forEach((a) => a.addEventListener("click", close));
    }
  }
</script>
