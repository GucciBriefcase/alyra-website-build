{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "astro build",
  "outputDirectory": "dist",
  "trailingSlash": true,
  "redirects": [
    { "source": "/loans/high-value-watches/", "destination": "/loans/luxury-watches/", "permanent": true },
    { "source": "/loans/classic-luxury-cars/", "destination": "/loans/classic-and-luxury-cars/", "permanent": true },
    { "source": "/insights/what-determines-fine-watch-value-2026/", "destination": "/insights/what-determines-fine-watch-value/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
